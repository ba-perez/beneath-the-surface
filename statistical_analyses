# --- MEAN SOC STOCKS ---

# Fit linear mixed-effects model
lmer_meanC <- lmer(
  Cstock_tperha ~ 
    condition * elevation_sc
  + condition * northerness_sc
  + (1 | triplet),
  data = soil_analyses_table,
  REML = TRUE
)

check_model(lmer_meanC)

