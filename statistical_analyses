# --- MEAN SOC STOCKS ---

# Fit linear mixed-effects model
lmer_meanC <- lmer(
  Cstock_tperha ~ 
    condition * elevation_sc
  + condition * northerness_sc
  + (1 | triplet),
  data = final_soil,
  REML = TRUE
)

