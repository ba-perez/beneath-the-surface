# --- MATCH FOREST PLOTS TO TRIPLETS ---

# Weighted Euclidean distance matching on terrain variables
# solved through Hungarian algorithm
 
# Matching variables
matching_vars <- c(
  "elevation_m",
  "northerness",
  "slope_deg", "tpi", "tri"
)
 
# Variable weights
weights <- c(
  elevation_m  = 2.00,
  northerness  = 0.50,
  slope_deg    = 0.10,
  tpi          = 0.10,
  tri          = 0.10
)
 
# Calculate triplet means across all matching variables
triplet_means <- soil_sf %>%
  st_drop_geometry() %>%
  group_by(triplet) %>%
  summarise(across(all_of(matching_vars), mean, na.rm = TRUE),
            .groups = "drop")
 
# Combine triplet and forest data for standardisation
# (matching variables only)
all_env <- bind_rows(
  triplet_means %>% dplyr::select(all_of(matching_vars)) %>% mutate(type = "triplet"),
  forest_sf     %>% dplyr::select(all_of(matching_vars)) %>% mutate(type = "wooded")
)
 
# Standardise matching variables (z-scores)
env_scaled <- all_env %>%
  mutate(across(all_of(matching_vars), ~scale(.)[, 1]))
 
# Split back into triplet and forest subsets
triplet_scaled <- env_scaled %>% filter(type == "triplet") %>% dplyr::select(-type)
wooded_scaled  <- env_scaled %>% filter(type == "wooded")  %>% dplyr::select(-type)
 
# Convert to matrices for cost calculation
n_trip <- nrow(triplet_scaled)
n_for  <- nrow(wooded_scaled)
 
triplet_matrix <- as.matrix(triplet_scaled[, matching_vars])
wooded_matrix  <- as.matrix(wooded_scaled[,  matching_vars])
 
# Cost matrix: squared weighted distance between each triplet-forest pair
cost_matrix <- matrix(NA, nrow = n_trip, ncol = n_for)
 
for (i in seq_len(n_trip)) {
  for (j in seq_len(n_for)) {
    diffs <- triplet_matrix[i, ] - wooded_matrix[j, ]
    cost_matrix[i, j] <- sum(weights * diffs^2)
  }
}
 
# Solve assignment (Hungarian algorithm)
assignment   <- solve_LSAP(cost_matrix, maximum = FALSE)
assigned_idx <- as.integer(assignment)
 
# Compile results, join triplet reference values for comparison
forest_assigned <- forest_sf %>%
  st_drop_geometry() %>%
  slice(assigned_idx)
 
results_hungarian <- data.frame(
  triplet          = triplet_means$triplet,
  matched_plot_ID  = forest_assigned$plot_ID,
  within_wimbach   = forest_assigned$within_wimbach,
  pair_cost        = cost_matrix[cbind(seq_len(n_trip), assigned_idx)],
  piab_percentage  = forest_assigned$piab_percentage,
  conif_percentage = forest_assigned$conif_percentage,
  # Elevation
  matched_elevation_m      = forest_assigned$elevation_m,
  triplet_elevation_m      = triplet_means$elevation_m,
  diff_elevation_m         = abs(triplet_means$elevation_m - forest_assigned$elevation_m),
  # Northerness
  matched_northerness      = forest_assigned$northerness,
  triplet_northerness      = triplet_means$northerness,
  diff_northerness         = abs(triplet_means$northerness - forest_assigned$northerness),
  # Slope
  matched_slope            = forest_assigned$slope_deg,
  triplet_slope            = triplet_means$slope_deg,
  diff_slope               = abs(triplet_means$slope_deg - forest_assigned$slope_deg),
  # TPI
  matched_tpi              = forest_assigned$tpi,
  triplet_tpi              = triplet_means$tpi,
  diff_tpi                 = abs(triplet_means$tpi - forest_assigned$tpi),
  # TRI
  matched_tri              = forest_assigned$tri,
  triplet_tri              = triplet_means$tri,
  diff_tri                 = abs(triplet_means$tri - forest_assigned$tri)
) %>%
  # Sort high to low elevation
  arrange(desc(triplet_elevation_m))
 
# Clean up intermediate objects
rm(
  weights, triplet_means, all_env,
  env_scaled, triplet_scaled, wooded_scaled,
  n_trip, n_for, triplet_matrix, wooded_matrix, cost_matrix,
  assignment, assigned_idx
)
 
gc()
 
