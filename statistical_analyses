# --- IMPORT AND PREPARE FORESTED PLOT DATA ---
 
# Soil depth measurements for forested plots
# Used to derive layer weights for soil chemistry calculations below
forest_soil_depth <- read_excel("forest_soil_depths.xlsx") %>%
  # Remove duplicate rows
  # (values are plot-level, all rows per plot_ID are identical)
  distinct(plot_ID, .keep_all = TRUE)
 
# Soil chemistry for forest plots
# Raw data has soil layers humus and tangel per plot
# Each plot was sampled at four corners, samples then pooled by layer type
# weight_humus + weight_tangel record 
# the proportion of corners where each layer was present
# used to weight layer contributions 
# when aggregating to a single plot estimate
# Plotsconsist entirely of humus/tangel up to 10 cm soil depth
# so results from mineral samples (always deeper layers) are excluded
forest_sf <- read.csv2("forest_soil_chemistry.csv") %>%
  # Exclude gap succession plots
  filter(!succession %in% c("gap")) %>%
  # Exclude gravel and mineral samples
  # (analysed plots are 100% humus/tangel in upper 10 cm)
  filter(!soil_type %in% c("gravel", "mineral")) %>%
  # Join soil depth data to obtain layer weights
  left_join(forest_soil_depth, by = "plot_ID") %>%
  # Assign layer-specific depths, calculate weighted values per soil type
  # Original values are overwritten by their weighted counterparts
  mutate(
    # Humus depth applies to tangel as well
    depth_in_10cm = depth_humus_standard,
    sample_mass   = bulk_density_gcm3 * depth_in_10cm,
    # pH: convert to H+ concentration weighted by mass
    H_conc        = 10^(-pH_KCl) * sample_mass,
    # C%: calculate C mass for the 10 cm sample
    Corg_mass     = (Corg_perc / 100) * sample_mass
  ) %>%
  # Pivot to one row per plot
  # Each soil layer as its own column set
  pivot_wider(
    id_cols     = c(plot_ID, weight_humus, weight_tangel),
    names_from  = soil_type,
    values_from = c(
      pH_KCl, H_conc, Corg_perc, Corg_stock_tperha,
      Corg_mass, sample_mass
    ),
    names_glue = "{.value}_{ifelse(soil_type == 'humus', 'hum', 'tan')}"
  ) %>%
  # Aggregate layer values to a single estimate per plot
  rowwise() %>%
  mutate(
    # C stock: weighted by proportion of plot corners with each layer type
    Corg_stock_tperha_10cm = sum(
      Corg_stock_tperha_hum * weight_humus,
      Corg_stock_tperha_tan * weight_tangel,
      na.rm = TRUE
    ),
    # pH: convert mass-weighted mean H+ back to pH scale
    total_mass   = sum(c_across(starts_with("sample_mass_")), na.rm = TRUE),
    pH_KCl_10cm  = -log10(
      sum(c_across(starts_with("H_conc_")), na.rm = TRUE) / total_mass
    ),
    # C%: mass-weighted average across layers
    Corg_perc_10cm = sum(c_across(starts_with("Corg_mass_")), na.rm = TRUE) /
      total_mass * 100
  ) %>%
  ungroup() %>%
  # Remove intermediate helper variables
  dplyr::select(-c(
    starts_with("H_conc_"),
    starts_with("Corg_mass_"),
    starts_with("sample_mass_"),
    total_mass
  ))

